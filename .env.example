# Anthropic API key for Claude diagnoses
ANTHROPIC_API_KEY=sk-ant-...

# Discord webhook URL (Channel Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXXXXXX/YYYYYYYY

# Path to the Conan Exiles server log on this host.
# Local path is preferred when this service runs on WINTOAD01 itself.
# UNC fallback example: \\WINTOAD01\ConanSaved\Logs\ConanSandbox.log
CONAN_LOG_PATH=C:\ConanSaved\Logs\ConanSandbox.log

# Number of lines to tail from the end of the log
LOG_TAIL_LINES=50

# Port the Flask listener binds to (0.0.0.0:<port>)
LISTENER_PORT=5555

# Minimum seconds between successive "down" diagnoses (debounce)
COOLDOWN_SECONDS=300

# Claude model id
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Set to "1" to also post a green embed on recovery (status=1) events
POST_RECOVERY_MESSAGES=1
